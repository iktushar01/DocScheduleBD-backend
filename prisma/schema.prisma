generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Speciality {
    id          String    @id @default(uuid())
    title       String    @unique @db.VarChar(100)
    description String?   
    icon        String?   @db.VarChar(255)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    deletedAt   DateTime?

    @@index([title], name: "specialities_title_idx")
    @@index([deletedAt], name: "specialities_deletedAt_idx")

    @@map("specialities")
}